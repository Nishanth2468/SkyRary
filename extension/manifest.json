{
  "manifest_version": 3,
  "name": "Sonic-Guard AI Reviewer",
  "version": "1.0",
  "description": "Autonomous AI Code Repository Management",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://github.com/*",
    "http://localhost:8000/*",
    "https://*.ngrok-free.dev/*",
    "https://*.ngrok-free.app/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://github.com/*/*/pull/*"],
      "js": ["content.js"],
      "css": ["style.css"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Sonic-Guard"
  }
}

# =========================================================
# Sonic-Guard — .env.example
# Copy to .env and fill in your values
# NEVER commit .env to git — only this placeholder file is safe to commit
# =========================================================

# ── Choose ONE LLM provider ──────────────────────────────
# Option A: Google Gemini (COMPLETELY FREE — recommended)
# Get key at: aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Option B: Anthropic Claude (free $5 credit on signup)
# Get key at: console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_key_here

# Set which provider to use: "gemini" or "anthropic"
LLM_PROVIDER=gemini

# ── GitHub ───────────────────────────────────────────────
# Create at: github.com/settings/tokens → Generate new token (classic)
# Required scope: repo (full control)
GITHUB_TOKEN=your_github_pat_here

# Webhook secret — generate with:
# python3 -c "import secrets; print(secrets.token_hex(20))"
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here
